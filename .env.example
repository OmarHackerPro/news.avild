# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────

# Docker Compose local dev — must match POSTGRES_PASSWORD in docker-compose.yml
DB_PASSWORD=password

# Full async DSN used by the FastAPI backend (asyncpg driver)
# Local (Docker):
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/avild_news
# Remote (cloud VM / Supabase / Neon / RDS):
# DATABASE_URL=postgresql+asyncpg://user:password@your-host:5432/dbname

# ─────────────────────────────────────────────────────────────────────────────
# OpenSearch
# ─────────────────────────────────────────────────────────────────────────────

# Port 9200 on the OpenSearch machine is bound to localhost only.
# You have two options:
#
# Option A — SSH tunnel (development / no firewall changes needed):
#   Open tunnel:  ssh -L 9200:localhost:9200 user@81.17.98.185
#   Then use:     OPENSEARCH_URL=https://localhost:9200
#
# Option B — Bind OpenSearch to 0.0.0.0 on the remote machine
#   (see README for opensearch.yml change + firewall rule)
#   Then use:     OPENSEARCH_URL=https://81.17.98.185:9200

OPENSEARCH_URL=https://localhost:9200

# Use the dedicated kiber_app user created during OpenSearch setup (see README).
# Never use the admin or Vaqif accounts in application config.
OPENSEARCH_USER=kiber_app
OPENSEARCH_PASSWORD=change-me

# ─────────────────────────────────────────────────────────────────────────────
# Auth / JWT
# ─────────────────────────────────────────────────────────────────────────────

SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─────────────────────────────────────────────────────────────────────────────
# SMTP (password reset emails — optional)
# Leave blank to log reset links to stdout instead of sending emails.
# ─────────────────────────────────────────────────────────────────────────────

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@kiber.info

# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────

APP_BASE_URL=http://localhost:8000
