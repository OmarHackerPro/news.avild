FROM nginx:alpine

# Copy static assets
COPY static/ /usr/share/nginx/html/static/

# Copy HTML pages (served as static files — no Jinja2 rendering needed)
COPY templates/index.html /usr/share/nginx/html/index.html
COPY templates/category.html /usr/share/nginx/html/category.html

# Nginx config
COPY nginx/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
